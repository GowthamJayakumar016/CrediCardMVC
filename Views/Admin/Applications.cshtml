@model List<CreditCardAppMvc.Models.Application>

<h3 class="text-primary mb-4">Applications</h3>

<table class="table table-bordered">

    <thead class="table-primary">

        <tr>
            <th>User</th>
            <th>PAN</th>
            <th>Income</th>
            <th>Credit Score</th>
            <th>Credit Limit</th>
            <th>Status</th>
            <th>Action</th>
        </tr>

    </thead>

    <tbody>

        @foreach (var app in Model)
        {
            <tr>

                <td>@app.User?.Name</td>
                <td>@app.PAN</td>
                <td>@app.AnnualIncome</td>
                <td>@app.CreditScore</td>
                <td>@app.CreditLimit</td>
                <td>@app.Status</td>

                <td>

                    @if (app.Status == "Pending")
                    {
                        <a class="btn btn-success btn-sm"
                           href="/Admin/Approve/@app.Id">
                            Approve
                        </a>

                        <a class="btn btn-danger btn-sm"
                           href="/Admin/Reject/@app.Id">
                            Reject
                        </a>
                    }

                </td>

            </tr>
        }

    </tbody>

</table>