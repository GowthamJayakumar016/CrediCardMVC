    <div class="col-md-4">

        <div class="card shadow">
            <div class="card-body text-center">

                <h5>Pending Applications</h5>

                <a href="/Admin/Applications?status=Pending"
                   class="btn btn-primary mt-3">
                    View
                </a>

            </div>
        </div>

    </div>


    <div class="col-md-4">

